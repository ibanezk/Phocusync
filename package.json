{
  "devDependencies": {
    "@tailwindcss/cli": "^4.3.0",
    "concurrently": "^10.0.3",
    "lite-server": "^2.6.1",
    "tailwindcss": "^4.3.0"
  },
  "scripts": {
    "dev": "concurrently \"tailwindcss -i styles.css -o output.css --watch\" \"lite-server\"",
    "postinstall": "cd app && npm install",
    "build": "tailwindcss -i styles.css -o output.css && cd app && npm run build"
  },
  "dependencies": {
    "jszip": "^3.10.1"
  }
}
